pipeline {
 agent any
 environment {
 SERVER_IP = '172.31.43.15' // target server  private IP address
 SSH_CREDENTIAL = 'gym-key'
 REPO_URL = 'https://github.com/sarveshghag-cloud/gym-static-website-task-.git'
 BRANCH = 'master'
 REMOTE_USER = 'ubuntu'
 REMOTE_PATH = '/var/www/html'
 }
 stages {
 stage('Clone Repository') {
 steps {
 git branch: "${BRANCH}", url: "${REPO_URL}"
 }
 }
 stage('Deploy to Target Server') {
    steps {
        sshagent([SSH_CREDENTIAL]) {
            sh """
            # copy files to temp folder
            scp -o StrictHostKeyChecking=no -r * ${REMOTE_USER}@${SERVER_IP}:/tmp/

            # move files using sudo
            ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} '
            sudo rm -rf ${REMOTE_PATH}/*
            sudo mv /tmp/* ${REMOTE_PATH}/
            '
            """
        }
    }
}
 stage('Restart Nginx') {
 steps {
 sshagent([SSH_CREDENTIAL]) {
 sh """
 ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} '
 sudo systemctl restart nginx
 '
 """
 }
 }
 }
 }
 post {
 success {
 echo 'Deployment Successful'
 }
 failure {
 echo 'Deployment Failed'
 }
 }
}
